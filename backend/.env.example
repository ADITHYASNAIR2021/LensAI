# LensAI Backend — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# Only two API keys are required to run LensAI.

# ── Required ──────────────────────────────────────────────────────────────────

# NVIDIA NIM — vision analysis, embeddings, code review, classifier
# Get free key: https://build.nvidia.com  (sign in → Get API Key)
NVIDIA_API_KEY=nvapi-...

# Anthropic Claude — primary LLM fallback and structured extraction
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Limits ────────────────────────────────────────────────────────────────────
# Free scans per day per user. Default: 20 (dev). Set to 5 in production.
FREE_SCANS_PER_DAY=20

# ── Database & Redis (docker-compose defaults) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lensai:lensai@localhost:5432/lensai
REDIS_URL=redis://localhost:6379/0

# ── Auth (optional — enables Google sign-in) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (optional — enables paid plans) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ── ElevenLabs TTS (optional — enables Read Aloud) ────────────────────────────
ELEVENLABS_API_KEY=

# ── CORS origins ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://lensai.app"]
