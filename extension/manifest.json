{
  "manifest_version": 3,
  "name": "LensAI — See More, Understand Everything",
  "short_name": "LensAI",
  "version": "1.0.0",
  "description": "Highlight any region on your screen — text, diagrams, code, charts — and get instant AI explanations without leaving your tab.",

  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "storage",
    "sidePanel",
    "scripting",
    "contextMenus",
    "notifications",
    "alarms",
    "offscreen",
    "identity"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*",
    "https://accounts.google.com/*"
  ],

  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LensAI — See More, Understand Everything"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/stealth.ts"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "commands": {
    "activate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Activate LensAI region selection"
    },
    "quick-fullpage-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Scan full page with LensAI"
    },
    "activate-comparison": {
      "suggested_key": {
        "default": "Ctrl+Shift+C",
        "mac": "Command+Shift+C"
      },
      "description": "Activate multi-region comparison mode"
    },
    "toggle-stealth": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Toggle stealth mode — hide LensAI overlays from screen share"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
